# ===== GitHub Configuration =====
# Your GitHub Personal Access Token (for API access)
# Get from: https://github.com/settings/tokens
# Scopes needed: repo, read:user
GITHUB_TOKEN=ghp_your_token_here

# Webhook secret (any random string you set in GitHub webhook settings)
# Leave empty to skip signature validation (useful for local testing)
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# ===== AI/LLM Configuration =====
# Google Gemini API Key
# Get from: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your_gemini_api_key_here

# Optional: Custom LLM model
# Default: gemini-1.5-flash
LLM_MODEL=gemini-1.5-flash

# ===== Server Configuration =====
# Port the uvicorn server runs on
PORT=8000

# Environment (development, staging, production)
ENVIRONMENT=development

# ===== Optional: MCP Configuration =====
# Model Context Protocol server settings
MCP_TIMEOUT=30
MCP_MAX_RETRIES=3

# ===== Optional: Logging =====
LOG_LEVEL=INFO
